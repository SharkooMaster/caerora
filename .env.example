# ============================================================
# Caerora environment configuration
# Copy this file to `.env` and fill in real values.
# ============================================================

# ---- General ----
# Host ports: storefront (frontend) and API (backend).
FRONTEND_PORT=8092
BACKEND_PORT=8091
# Comma-separated list. "dev" or "prod"
DJANGO_SETTINGS_MODULE=caerora.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=1
# Hosts Django will serve (comma separated)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Public site origin (storefront) used for emails, links, CSRF, CORS
SITE_URL=http://localhost:8092
FRONTEND_ORIGIN=http://localhost:8092
# Public origin where the backend/admin is reachable by the browser
BACKEND_ORIGIN=http://localhost:8091
# Comma-separated extra CORS origins (optional)
CORS_EXTRA_ORIGINS=

# ---- Database (Postgres) ----
POSTGRES_DB=caerora
POSTGRES_USER=caerora
POSTGRES_PASSWORD=caerora
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# 3-letter default currency (lowercase), overridden per shipping zone
STRIPE_DEFAULT_CURRENCY=eur

# ---- Resend (transactional email) ----
RESEND_API_KEY=re_xxx
EMAIL_FROM="Caerora <hello@caerora.com>"
# Where order/admin notifications are sent
ADMIN_NOTIFICATION_EMAIL=orders@caerora.com

# ---- Marketing / analytics (public, exposed to the browser) ----
# Leave blank to disable a given integration.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
# Google Ads tag (AW-XXXXXXXXX) + the purchase conversion label from
# Ads > Goals > Conversions (the part after the slash in send_to)
# Production tag: AW-18284609416
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_LABEL=
# Server-side Meta Conversions API token (kept private)
META_CAPI_ACCESS_TOKEN=
META_CAPI_PIXEL_ID=
# GA4 Measurement Protocol (server-side purchase events)
GA4_API_SECRET=

# ---- Frontend ----
# Base URL the browser uses to reach the API (backend on port 8091)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8091/api
NEXT_PUBLIC_SITE_URL=http://localhost:8092
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Internal URL the Next.js server uses for SSR fetches (container network)
INTERNAL_API_BASE_URL=http://backend:8000/api
# Public base URL for media files so images load in the browser
MEDIA_PUBLIC_BASE_URL=http://localhost:8091

# ---- Django superuser (auto-created on first boot if set) ----
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@caerora.com
DJANGO_SUPERUSER_PASSWORD=change-me-admin-pass
